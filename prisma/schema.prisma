generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum SubscriptionStatus {
  ACTIVE
  LAPSED
  CANCELLED
}

enum Plan {
  MONTHLY
  YEARLY
}

enum DrawLogic {
  RANDOM
  ALGORITHMIC
}

enum PayoutStatus {
  PENDING
  PAID
  REJECTED
}

model User {
  id                String       @id @default(cuid())
  name              String
  email             String       @unique
  passwordHash      String
  role              Role         @default(USER)
  charityPercent    Int          @default(10)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  charityId         String?
  charity           Charity?     @relation(fields: [charityId], references: [id], onDelete: SetNull)
  subscription      Subscription?
  scores            Score[]
  drawResults       DrawResult[]
  donations         Donation[]
  notifications     Notification[]
}

model Subscription {
  id          String             @id @default(cuid())
  userId      String             @unique
  plan        Plan
  amount      Int
  status      SubscriptionStatus @default(ACTIVE)
  renewalDate DateTime
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Score {
  id        String   @id @default(cuid())
  userId    String
  scoreDate DateTime
  value     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, scoreDate])
}

model Charity {
  id                 String   @id @default(cuid())
  name               String
  slug               String   @unique
  description        String
  imageUrl           String?
  upcomingEvent      String?
  isFeatured         Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  users              User[]
}

model Draw {
  id                String      @id @default(cuid())
  month             Int
  year              Int
  logicType         DrawLogic
  winningNumbersCsv String
  isPublished       Boolean     @default(false)
  jackpotRollover   Int         @default(0)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  results           DrawResult[]

  @@unique([month, year])
}

model DrawResult {
  id           String       @id @default(cuid())
  drawId       String
  userId       String
  matchCount   Int
  tier         Int
  payoutAmount Int
  status       PayoutStatus @default(PENDING)
  proofUrl     String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  draw         Draw         @relation(fields: [drawId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Donation {
  id        String   @id @default(cuid())
  userId    String
  amount    Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  subject   String
  message   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
